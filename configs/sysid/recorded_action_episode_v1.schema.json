{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sim2claw.local/contracts/recorded_action_episode_v1.schema.json",
  "title": "sim2claw recorded-action episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episode_id",
    "proof_class",
    "proof_class_category",
    "joint_names",
    "initial_state",
    "initial_object_state",
    "samples"
  ],
  "properties": {
    "schema_version": {
      "const": "sim2claw.recorded_action_episode.v1"
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "proof_class": {
      "type": "string",
      "minLength": 1
    },
    "proof_class_category": {
      "enum": [
        "fixture",
        "synthetic",
        "simulation",
        "replay",
        "learned_policy",
        "physical_read_only",
        "physical_task"
      ]
    },
    "column": {
      "type": ["string", "null"],
      "pattern": "^[a-hA-H]$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "joint_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "initial_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "joint_position",
        "joint_position_units",
        "joint_velocity",
        "joint_velocity_units"
      ],
      "properties": {
        "joint_position": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number"}
        },
        "joint_velocity": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number"}
        },
        "joint_position_units": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["radian", "meter"]}
        },
        "joint_velocity_units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["radian_per_second", "meter_per_second"]
          }
        }
      }
    },
    "initial_object_state": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason"],
          "properties": {
            "status": {"const": "unavailable"},
            "reason": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "body_name",
            "free_joint_name",
            "frame",
            "position_unit",
            "orientation_convention",
            "linear_velocity_unit",
            "angular_velocity_unit",
            "position",
            "quaternion_wxyz",
            "linear_velocity",
            "angular_velocity",
            "measurement_provenance"
          ],
          "properties": {
            "status": {"const": "available"},
            "body_name": {"type": "string", "minLength": 1},
            "free_joint_name": {"type": "string", "minLength": 1},
            "frame": {"const": "world"},
            "position_unit": {"const": "m"},
            "orientation_convention": {"const": "wxyz_unit_quaternion"},
            "linear_velocity_unit": {"const": "m/s"},
            "angular_velocity_unit": {"const": "rad/s"},
            "position": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {"type": "number"}
            },
            "quaternion_wxyz": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {"type": "number"}
            },
            "linear_velocity": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {"type": "number"}
            },
            "angular_velocity": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {"type": "number"}
            },
            "measurement_provenance": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id", "measurement_method", "sha256"],
              "properties": {
                "source_id": {"type": "string", "minLength": 1},
                "measurement_method": {"type": "string", "minLength": 1},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          }
        }
      ]
    },
    "unavailable_observables": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "samples": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp_seconds", "command_joint_position", "measured"],
        "properties": {
          "timestamp_seconds": {"type": "number", "minimum": 0},
          "command_joint_position": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "number"}
          },
          "measured": {
            "type": "object",
            "additionalProperties": false,
            "required": ["joint_position"],
            "properties": {
              "joint_position": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "number"}
              },
              "end_effector_position_m": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {"type": "number"}
              },
              "end_effector_quaternion_wxyz": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {"type": "number"}
              },
              "gripper_position": {"type": "number"},
              "pawn_position_m": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {"type": "number"}
              },
              "pawn_quaternion_wxyz": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {"type": "number"}
              },
              "contact_active": {"type": "boolean"},
              "contact_force_n": {"type": "number", "minimum": 0}
            }
          }
        }
      }
    }
  }
}
