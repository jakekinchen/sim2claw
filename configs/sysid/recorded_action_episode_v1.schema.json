{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sim2claw.local/contracts/recorded_action_episode_v1.schema.json",
  "title": "sim2claw recorded-action episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episode_id",
    "proof_class",
    "proof_class_category",
    "joint_names",
    "initial_state",
    "samples"
  ],
  "properties": {
    "schema_version": {
      "const": "sim2claw.recorded_action_episode.v1"
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "proof_class": {
      "type": "string",
      "minLength": 1
    },
    "proof_class_category": {
      "enum": [
        "fixture",
        "synthetic",
        "simulation",
        "replay",
        "learned_policy",
        "physical_read_only",
        "physical_task"
      ]
    },
    "column": {
      "type": ["string", "null"],
      "pattern": "^[a-hA-H]$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "joint_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "initial_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["joint_position"],
      "properties": {
        "joint_position": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number"}
        },
        "joint_velocity": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number"}
        }
      }
    },
    "unavailable_observables": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "samples": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp_seconds", "command_joint_position", "measured"],
        "properties": {
          "timestamp_seconds": {"type": "number", "minimum": 0},
          "command_joint_position": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "number"}
          },
          "measured": {
            "type": "object",
            "additionalProperties": false,
            "required": ["joint_position"],
            "properties": {
              "joint_position": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "number"}
              },
              "end_effector_position_m": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {"type": "number"}
              },
              "end_effector_quaternion_wxyz": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {"type": "number"}
              },
              "gripper_position": {"type": "number"},
              "pawn_position_m": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {"type": "number"}
              },
              "pawn_quaternion_wxyz": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {"type": "number"}
              },
              "contact_active": {"type": "boolean"},
              "contact_force_n": {"type": "number", "minimum": 0}
            }
          }
        }
      }
    }
  }
}
