{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sim2claw.orchestrator_event.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sequence", "session_id", "event", "recorded_at", "payload", "physical_authority"],
  "properties": {
    "schema_version": {"const": "sim2claw.orchestrator_event.v1"},
    "sequence": {"type": "integer", "minimum": 0},
    "session_id": {"type": "string", "minLength": 1},
    "event": {"type": "string", "minLength": 1},
    "recorded_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object"},
    "physical_authority": {"const": false}
  }
}
