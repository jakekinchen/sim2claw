  "mechanism_hypotheses": [
    {
      "id": "H1_solver_creep",
      "probe": "no-slip solver iterations and solver algorithm",
      "distinguishing_prediction": "contact-force and surface position remain stable without changing initial contact geometry"
    },
    {
      "id": "H2_friction_constraint_model",
      "probe": "elliptic versus pyramidal cone and rubber contact dimensionality",
      "distinguishing_prediction": "tangential or torsional constraint behavior changes at the same contact surfaces"
    },
    {
      "id": "H3_contact_compliance_distribution",
      "probe": "bounded contact impedance and reference families",
      "distinguishing_prediction": "load shares across both jaws without upward surface migration"
    },
    {
      "id": "H4_surface_migration_geometry",
      "probe": "identity-rich contact witnesses followed by one bounded pad-surface geometry family",
      "distinguishing_prediction": "the load-bearing pair remains below the pawn head-collar transition and retention rises"
    },
    {
      "id": "H5_gripper_squeeze_dynamics",
      "probe": "existing gripper response witnesses only unless H1-H4 fail",
      "distinguishing_prediction": "simulated jaw separation grows under load despite an unchanged closed command"
    },
    {
      "id": "H6_scene_path_inconsistency",
      "probe": "wrong-piece contact and collateral event ledger",
      "distinguishing_prediction": "task failure is caused before or independently of selected-pawn retention"
    }
  ],
